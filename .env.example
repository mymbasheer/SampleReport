# ─────────────────────────────────────────────────────────────
# BizLedger — Environment Variables
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────

# ── Local PC Development ──────────────────────────────────────
# When running locally, no env vars are needed.
# The app defaults to http://localhost:5000
# Just run:  npm run dev

# ── Cloud / Production Hosting ────────────────────────────────
# Set this to the full URL of your deployed server:
# EXPO_PUBLIC_API_URL=https://your-server.com

# ── CORS (server-side) ────────────────────────────────────────
# Comma-separated list of allowed origins for the API server.
# Localhost is always allowed automatically.
# ALLOWED_ORIGINS=https://your-server.com,https://your-other-domain.com

# ── Server Port ───────────────────────────────────────────────
# Default is 5000. Change if needed.
# PORT=5000
